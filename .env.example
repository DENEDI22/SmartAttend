# SmartAttend — Environment Variable Reference
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────
# SQLite path inside the container (maps to ./data/ on host via volume)
DATABASE_URL=sqlite:////app/data/smartattend.db

# ── MQTT Broker ───────────────────────────────────────────────────────────
# Docker service name (inside compose network) or IP for external broker
MQTT_BROKER=mqtt
MQTT_PORT=1883

# ── Network ───────────────────────────────────────────────────────────────
# Public base URL used in check-in token URLs sent to NFC devices
# For development: http://localhost:8000
# For production with ngrok: https://your-domain.ngrok-free.app
BASE_URL=http://localhost:8000

# ── Ngrok (production only) ────────────────────────────────────────────
# Get auth token from https://dashboard.ngrok.com
# Reserve a domain at https://dashboard.ngrok.com/domains
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ── Admin Bootstrap ───────────────────────────────────────────────────────
# If set, creates an admin account on first boot (idempotent).
# Leave empty to skip bootstrap (useful if managing users via API).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-boot
