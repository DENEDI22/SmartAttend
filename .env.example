# SmartAttend — Environment Variable Reference
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real secrets.

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────
# SQLite path inside the container (maps to ./data/ on host via volume)
DATABASE_URL=sqlite:////app/data/smartattend.db

# ── MQTT Broker ───────────────────────────────────────────────────────────
# Docker service name (inside compose network) or IP for external broker
MQTT_BROKER=mqtt
MQTT_PORT=1883

# ── Network ───────────────────────────────────────────────────────────────
# IP address of this Raspberry Pi — used in token URLs sent to NFC devices
# Example: SERVER_IP=192.168.1.42
SERVER_IP=localhost
